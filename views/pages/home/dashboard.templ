package home

templ Dashboard() {
	<div class="hero min-h-[60vh]">
		<div class="hero-content text-center">
			<div class="max-w-md">
				<h1 class="text-5xl font-bold">Welcome to Soccer Stats</h1>
				<p class="py-6 text-base-content/60">
					Track matches, stats, and results for your soccer group.
					Create or join a group to get started.
				</p>
				<a href="/groups" class="btn btn-primary">My Groups</a>
			</div>
		</div>
	</div>
}
